{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.wind_charge": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"hold": "query.get_equipped_item_name('offhand')=='wind_charge'&&!query.is_using_item"
						},
						{
							"throw": "query.get_equipped_item_name('offhand')=='wind_charge'&&query.is_using_item&&!query.is_sneaking"
						},
						{
							"ground_boost": "query.get_equipped_item_name('offhand')=='wind_charge'&&query.is_using_item&&query.is_sneaking"
						}
					]
				},
				"hold": {
					"animations": [
						"wind_charge_hold_1st",
						"wind_charge_hold_3rd"
					],
					"transitions": [
						{
							"default": "query.get_equipped_item_name('offhand')!='wind_charge'"
						},
						{
							"throw": "query.is_using_item&&!query.is_sneaking"
						},
						{
							"ground_boost": "query.is_using_item&&query.is_sneaking"
						}
					]
				},
				"throw": {
					"animations": [
						"wind_charge_throw_1st",
						"wind_charge_throw_3rd"
					],
					"transitions": [
						{
							"default": "query.get_equipped_item_name('offhand')!='wind_charge'"
						},
						{
							"hold": "!query.is_using_item"
						}
					]
				},
				"ground_boost": {
					"animations": [
						"wind_charge_ground_boost_1st",
						"wind_charge_ground_boost_3rd"
					],
					"transitions": [
						{
							"default": "query.get_equipped_item_name('offhand')!='wind_charge'"
						},
						{
							"hold": "!query.is_using_item"
						}
					]
				}
			}
		}
	}
}